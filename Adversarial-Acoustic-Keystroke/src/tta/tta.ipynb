import os
import pandas as pd
import librosa
import soundfile as sf
import random
import shutil  


def generate_word_audio(word, audio_folder="data_noiseless_final"):
    
    # Path to labels CSV (root folder)
    labels_path = "labels_data.csv"
    
    if not os.path.exists(labels_path):
        print("[ERROR] labels_data.csv not found!")
        return
    
    # Load and clean CSV
    labels = pd.read_csv(labels_path)
    labels.columns = labels.columns.str.strip()
    labels.iloc[:, 1] = labels.iloc[:, 1].astype(str).str.lower()
    
    output_folder = "output_letters"
    
    if os.path.exists(output_folder):
        shutil.rmtree(output_folder)
        print(f"[INFO] Cleared existing folder: {output_folder}")
    
    folder_created = False  # Create only when needed
    
    for index, char in enumerate(word.lower(), start=1):
        
        if char == " ":
            continue
        
        # Find matching rows for character
        matches = labels[labels.iloc[:, 1] == char]
        
        if matches.empty:
            print(f"[WARN] No audio found for '{char}'")
            continue
        
        # Pick a random file (e.g., e_09.wav)
        filename = random.choice(matches.iloc[:, 0].values)
        
        # Convert to actual filename (e.g., key-e-09.wav)
        real_filename = "key-" + filename.replace("_", "-")
        file_path = os.path.join(audio_folder, real_filename)
        
        print(f"trying: {file_path}")
        
        if not os.path.exists(file_path):
            print(f"[error] File not found: {file_path}")
            continue
        
        try:
            audio, sr = librosa.load(file_path, sr=16000)
            
            # Create output folder only when first file is saved
            if not folder_created:
                os.makedirs(output_folder, exist_ok=True)
                folder_created = True
            
            output_name = os.path.join(output_folder, f"{char}_{index}.wav")
            sf.write(output_name, audio, 16000)
            
            print(f"[OK] Saved: {output_name}")
        
        except Exception as e:
            print(f"[ERROR] Failed loading {file_path} | {e}")
    
    # Remove folder if it exists but is empty
    if os.path.exists(output_folder) and not any(os.scandir(output_folder)):
        os.rmdir(output_folder)
        print(f"Removed empty folder: {output_folder}")


# Example usage
word = "cyber"
generate_word_audio(word)